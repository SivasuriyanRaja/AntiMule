# ─────────────────────────────────────────────────────
# AntiMule — Environment Configuration
# cp .env.example .env  →  fill in your values
# NEVER commit the .env file to GitHub
# ─────────────────────────────────────────────────────

# ── Active backend: "mongodb" | "mysql" | "both" ──────
DB_BACKEND=mongodb

# ── MongoDB ────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=antimule

# ── MySQL ───────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=yourpassword
MYSQL_DB=antimule

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8005
