# ─────────────────────────────────────────────────────
# AntiMule — Environment Configuration
# cp .env.example .env  →  fill in your values
# NEVER commit the .env file to GitHub
# ─────────────────────────────────────────────────────

# ── Database backend: use "mongodb" (no MySQL needed) ─
DB_BACKEND=mongodb

# ── MongoDB (required) ─────────────────────────────────
# Free cluster at: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.xxxxx.mongodb.net
MONGO_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net
MONGO_DB=antimule

# ── MySQL (optional — leave blank if not used) ─────────
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DB=antimule

# ── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8005

# ── Auth ─────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-please-change-in-prod
